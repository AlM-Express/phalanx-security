network:
  # Allows network module usage IF they target these approved domains
  allow:
    - github.com
    - registry.npmjs.org
  # Critical flag trigger if network access is attempted to these
  block:
    - malicious-c2.example.com
    - pastebin.com

integrity:
  block:
    - "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
